# Required
TELEGRAM_CHANNEL_ID=-1001234567890    # Target Telegram chat/channel (get from @userinfobot)
TELEGRAM_BOT_TOKEN=123456:ABC-...     # Bot token from @BotFather
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key from console.anthropic.com

# Monitoring / Alerting
TELEGRAM_ADMIN_CHAT_ID=              # Your personal chat ID for failure alerts (get from @userinfobot)

# Telegram Authentication (for telethon client)
TELEGRAM_API_ID=12345678              # Get from https://my.telegram.org/apps
TELEGRAM_API_HASH=abcdef1234567890... # Get from https://my.telegram.org/apps
TELEGRAM_SESSION=                     # Optional: Auto-saved after first authentication

# Telegram Scraper Configuration (Optional)
TELEGRAM_FOLDER_ID=                   # Optional: Only scrape channels in this folder ID
TELEGRAM_MAX_MESSAGES_PER_CHANNEL=10  # Max messages per channel (default: 10)
TELEGRAM_SCRAPE_HOURS=24              # Look back N hours (default: 24)

# Optional
PUSH_TIME=08:00                       # Cron schedule override (default: 08:00)
MAX_ARTICLES=10                       # Max articles to process per run (default: 10)
MUST_READ_COUNT=3                     # Number of Must-Read articles (default: 3)
DB_PATH=./db/articles.db              # SQLite database path (default: ./db/articles.db)
LOG_LEVEL=INFO                        # Logging level: DEBUG|INFO|WARNING|ERROR
